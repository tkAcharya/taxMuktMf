{
  "manifest_version": 3,
  "name": "CAS Analyzer — MF Portfolio & LTCG Calculator",
  "version": "1.0.0",
  "description": "Upload your CAMS/Karvy CAS PDF to analyze your mutual fund portfolio and compute LTCG tax harvesting opportunities.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "CAS Analyzer"
  },
  "permissions": [],
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16":  "icons/icon16.svg",
    "48":  "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
